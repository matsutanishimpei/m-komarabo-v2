{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "@cloudflare/workers-types"]
  },
  "include": [
    "vitest.config.ts",
    "playwright.config.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "functions/**/*.ts"
  ]
}
